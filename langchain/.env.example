# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_FLASHCARD_MODEL=gpt-4o-mini
OPENAI_EXAM_MODEL=gpt-4o-mini

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# Shared secret with NestJS backend (must match AI_SERVICE_SECRET in backend .env)
AI_SERVICE_SECRET=change-me-shared-secret

# NestJS backend URL for status callbacks
NESTJS_URL=http://localhost:3000/api/v1

# Server
PORT=8000
