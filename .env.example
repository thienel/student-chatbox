# ============================================================
# EduChat — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=educhat_secret

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- JWT (generate with: openssl rand -base64 64) ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Frontend (khi dùng proxy qua nginx, để /api/v1) ---
VITE_API_URL=/api/v1
